# Redmond Desktop — barre des tâches façon Windows (tint2)

# --- Fond 1 : barre (sombre, légèrement translucide)
rounded = 0
border_width = 0
background_color = #1f1f1f 85
border_color = #1f1f1f 0

# --- Fond 2 : tâche active
rounded = 3
border_width = 0
background_color = #4d4d4d 70
border_color = #ffffff 0

# --- Fond 3 : tâche survolée
rounded = 3
border_width = 0
background_color = #3a3a3a 60
border_color = #ffffff 0

#---- Panel
panel_items = LTSC
panel_size = 100% 40
panel_margin = 0 0
panel_padding = 4 2 6
panel_background_id = 1
panel_position = bottom center horizontal
panel_layer = top
panel_monitor = all
wm_menu = 1
strut_policy = follow_size

#---- Launcher : bouton Démarrer
launcher_padding = 6 4 4
launcher_background_id = 0
launcher_icon_theme_override = 0
launcher_icon_size = 26
launcher_item_app = ~/.local/share/applications/redmond-menu.desktop
launcher_tooltip = 1

#---- Taskbar
taskbar_mode = single_desktop
taskbar_padding = 4 2 4
taskbar_background_id = 0
taskbar_name = 0

#---- Tâches
task_text = 1
task_icon = 1
task_centered = 0
task_maximum_size = 180 34
task_padding = 8 4 6
task_font = Sans 9
task_font_color = #ffffff 100
task_background_id = 0
task_active_background_id = 2
task_hover_background_id = 3
task_icon_asb = 100 0 0
mouse_left = toggle_iconify
mouse_middle = close
mouse_scroll_up = none
mouse_scroll_down = none

#---- Zone de notification (systray)
systray_padding = 4 2 6
systray_background_id = 0
systray_sort = ascending
systray_icon_size = 20
systray_icon_asb = 100 0 0

#---- Horloge
time1_format = %H:%M
time2_format = %d/%m/%Y
time1_font = Sans 10
time2_font = Sans 8
clock_font_color = #ffffff 100
clock_padding = 8 2
clock_background_id = 0
clock_lclick_command =
clock_rclick_command =

#---- Info-bulles
tooltip_show_timeout = 0.5
tooltip_hide_timeout = 0.2
tooltip_padding = 6 4
tooltip_background_id = 1
tooltip_font = Sans 9
tooltip_font_color = #ffffff 100
